<?xml version="1.0"?>
<robot name="platform" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Platform dimensions -->
  <xacro:property name="platform_length" value="1.5" />
  <xacro:property name="platform_width" value="1.5" />
  <xacro:property name="platform_height" value="0.5" />
  <xacro:property name="marker_size" value="1.0" />

  <!-- Base link -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="50.0"/>
      <inertia ixx="9.375" ixy="0.0" ixz="0.0" iyy="9.375" iyz="0.0" izz="18.75"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${platform_length} ${platform_width} ${platform_height}"/>
      </geometry>
      <material name="platform_grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${platform_length} ${platform_width} ${platform_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- ArUco marker on top surface -->
  <link name="marker_link">
    <visual>
      <origin xyz="0 0 0.001" rpy="0 0 0"/>
      <geometry>
        <box size="${marker_size} ${marker_size} 0.001"/>
      </geometry>
      <material name="marker_material">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
  </link>

  <joint name="marker_joint" type="fixed">
    <parent link="base_link"/>
    <child link="marker_link"/>
    <origin xyz="0 0 ${platform_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- GPS link -->
  <link name="gps_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.02"/>
      </geometry>
      <material name="gps_grey">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
  </link>

  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps_link"/>
    <origin xyz="0.6 0.6 ${platform_height/2 + 0.01}" rpy="0 0 0"/>
  </joint>

</robot>